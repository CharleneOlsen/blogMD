---
import { getCollection, render } from "astro:content";
import Layout from "@/layouts/Layout.astro";
import Main from "@/layouts/Main.astro";

const allPoems = await getCollection("poetry");
const sortedPoems = allPoems
  .filter((poem) => !poem.data.draft)
  .sort((a, b) => b.data.pubDatetime.valueOf() - a.data.pubDatetime.valueOf());

const poems = await Promise.all(
  sortedPoems.map(async (poem) => {
    const { Content } = await render(poem);
    return {
      ...poem,
      Content,
      date: poem.data.pubDatetime.toLocaleDateString("en-GB", {
        day: "2-digit",
        month: "short",
        year: "numeric",
      }),
      slug: poem.data.slug ?? poem.id.replace(/\.md$/, ""),
    };
  })
);
---

<Layout title="poetry">
  <Main pageTitle="poetry" pageDesc="A collection of my poems.">
    <div class="mx-auto grid items-stretch gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {poems.map((poem) => {
        const Component = poem.Content;
        return (
          <article
            data-poem-id={poem.slug}
            class="relative flex h-full min-h-[360px] flex-col justify-between overflow-hidden rounded-xl border border-border/50 bg-background/95 p-6 shadow-[0_20px_45px_-25px_rgba(0,0,0,0.45)] transition-all duration-300 hover:-translate-y-1 hover:shadow-[0_28px_75px_-30px_rgba(0,0,0,0.5)]"
          >
            <div>
              <div class="mb-4 flex flex-wrap items-center justify-between gap-3">
                <span class="rounded-full bg-accent/10 px-3 py-1 text-[0.65rem] font-bold uppercase tracking-[0.3em] text-accent">
                  {poem.date}
                </span>
              </div>
              <h2 class="text-xl font-semibold lowercase text-foreground">{poem.data.title}</h2>
              <div class="mt-4 prose prose-sm max-w-none text-sm text-muted max-h-28 overflow-hidden">
                <Component />
              </div>
            </div>
            <div class="mt-6 flex justify-end">
              <button
                type="button"
                class="group relative bg-background px-2 py-1 size-14 rounded-full shadow-xl text-sm font-semibold text-foreground transition hover:bg-accent/10 md:h-8 md:w-fit md:rounded-md md:shadow-none md:bg-background/35 md:bg-clip-padding md:backdrop-blur-lg"
                data-poem-open={poem.slug}
              >
                read note
              </button>
            </div>
            <div class="poem-html hidden">
              <Component />
            </div>
          </article>
        );
      })}
    </div>

    <div
      id="poem-overlay"
      class="fixed inset-0 z-50 hidden items-start justify-center bg-black/70 p-4 pt-20 backdrop-blur-sm"
    >
      <div class="relative mx-auto flex w-full max-w-4xl min-h-[420px] max-h-[88vh] flex-col overflow-hidden rounded-xl border border-border/70 bg-background p-8 shadow-[0_24px_80px_-35px_rgba(0,0,0,0.8)]">
        <button
          id="poem-close"
          type="button"
          class="absolute right-4 top-4 group relative bg-background px-2 py-1 size-14 rounded-full shadow-xl text-sm font-semibold text-foreground transition hover:bg-accent/10 md:h-8 md:w-fit md:rounded-md md:shadow-none md:bg-background/35 md:bg-clip-padding md:backdrop-blur-lg"
        >
          close
        </button>

        <h2 id="poem-modal-title" class="mt-3 text-4xl font-semibold lowercase text-foreground"></h2>
        <div id="poem-modal-body" class="mt-6 prose prose-lg max-w-none text-foreground"></div>
      </div>
    </div>
  </Main>

  <script is:inline>
    const openButtons = document.querySelectorAll("button[data-poem-open]");
    const overlay = document.getElementById("poem-overlay");
    const closeButton = document.getElementById("poem-close");
    const titleElem = document.getElementById("poem-modal-title");
    const bodyElem = document.getElementById("poem-modal-body");

    const setOverlayVisible = (visible) => {
      if (!overlay) return;
      overlay.classList.toggle("hidden", !visible);
      document.body.style.overflow = visible ? "hidden" : "";
    };

    openButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const id = button.dataset.poemOpen;
        const card = document.querySelector(`article[data-poem-id="${id}"]`);
        if (!card || !titleElem || !bodyElem) return;

        titleElem.textContent = card.querySelector("h2")?.textContent || "";
        bodyElem.innerHTML = card.querySelector(".poem-html")?.innerHTML ?? "";
        setOverlayVisible(true);
      });
    });

    closeButton?.addEventListener("click", () => setOverlayVisible(false));
    overlay?.addEventListener("click", (event) => {
      if (event.target === overlay) setOverlayVisible(false);
    });
  </script>
</Layout>