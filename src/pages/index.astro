---
import { getCollection } from "astro:content";
import enrichPosts from "@/utils/enrichPosts";
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import LinkButton from "@/components/LinkButton.astro";
import Card from "@/components/Card.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import { SITE } from "@/config";
import { FEATURED_POSTS } from "@/data/featured";

const rawPosts = await getCollection("blog");
const posts = await enrichPosts(rawPosts);

const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ id }) =>
  FEATURED_POSTS.some(slug => slug.toLowerCase() === id.toLowerCase())
);
const recentPosts = sortedPosts.filter(({ id }) =>
  !FEATURED_POSTS.some(slug => slug.toLowerCase() === id.toLowerCase())
);
---

<Layout>
  <!-- <Header /> -->
  <main id="main-content" data-layout="index" class="app-layout">
    <section id="hero" class:list={["pt-8 pb-6", "border-b border-border"]}>
      <!-- <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
        Howdy
      </h1> -->

      <!-- <p> -->
      <p>Hi there, </p>
      <p>my name is <strong style="color: #0FFFF3;">Charli</strong>, it is so nice to meet you.</p>
      <p>Welcome to my digital garden. I am a polymath studying chemical engineering and my mind is always split between science and art. I am a curious soul, self-learning different topics that I lay my eyes on. In my free time, I write poems and short stories and paint ornaments.</p>
      <p>Feel free to roam the lab - my little cabinet of curiosities. </p>
      <!-- </p> -->
      <p class="mt-2">
      </p>
      <!-- {
        SOCIALS.length > 0 && (
          <div class="mt-4 flex max-sm:flex-col sm:items-center">
            <Socials />
          </div>
        )
      } -->
    </section>

    {
      featuredPosts.length > 0 && (
        <section
          id="featured"
          class:list={[
            "pt-12 pb-6",
            { "border-b border-border": recentPosts.length > 0 },
          ]}
        >
          <h2 class="text-2xl font-semibold tracking-wide">featured</h2>
          <ul>
            {featuredPosts.map(data => (
              <Card variant="h3" {...data} />
            ))}
          </ul>
        </section>
      )
    }

    {
      recentPosts.length > 0 && (
        <section id="recent-posts" class="pt-12 pb-6">
          <h2 class="text-2xl font-semibold tracking-wide">recent posts</h2>
          <ul>
            {recentPosts.map(
              (data, index) =>
                index < SITE.postPerIndex && <Card variant="h3" {...data} />
            )}
          </ul>
        </section>
      )
    }

    <div class="my-8 text-center">
      <LinkButton href="/posts/">
        all posts
        <IconArrowRight class="inline-block rtl:-rotate-180" />
      </LinkButton>
    </div>
  </main>
  <Footer />
</Layout>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset?.layout;
    if (indexLayout) {
      sessionStorage.setItem("backUrl", "/");
    }
  });
</script>
