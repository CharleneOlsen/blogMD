---
import type { GetStaticPaths } from "astro";
import { getCollection } from "astro:content";
import enrichPosts from "@/utils/enrichPosts";
import Main from "@/layouts/Main.astro";
import Layout from "@/layouts/Layout.astro";
import Footer from "@/components/Footer.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getSortedPosts from "@/utils/getSortedPosts";
import { SITE } from "@/config";

export const getStaticPaths = (async ({ paginate }) => {
  const rawPosts = await getCollection("blog", ({ data }) => !data.draft);
  const posts = await enrichPosts(rawPosts);
  const synthesizerPosts = getSortedPosts(posts).filter(
    post => post.filePath?.includes("/synthesizer/")
  );

  return paginate(synthesizerPosts, { pageSize: SITE.postPerPage });
}) satisfies GetStaticPaths;

const { page } = Astro.props;
---

<Layout title={`Synthesizer | ${SITE.title}`}>
  <Main
    pageTitle="the synthesizer"
    pageDesc="The synthesizer room filled with reviews."
  >
    <ul>
      {page.data.map(data => <Card {...data} />)}
    </ul>
  </Main>

  <Pagination {page} />

  <Footer noMarginTop={page.lastPage > 1} />
</Layout>
