---
import IconHash from "@/assets/icons/IconHash.svg";

type Props = {
  tag: string;
  tagName: string;
  size?: "sm" | "lg";
  variant?: "inline" | "list"; // Add this
};

const { tag, tagName, size = "lg", variant = "inline" } = Astro.props;
---

<li class:list={[{ "w-full": variant === "list" }]}> 
  <a
    href={`/tags/${tag}/`}
    transition:name={tag}
    class:list={[
      "flex items-center transition-all duration-200 focus-visible:text-accent",
      
      // Styles ONLY for the vertical list (Tags Page)
      variant === "list" && "border-b border-foreground/20 py-2 hover:border-accent hover:text-accent hover:pl-2 w-full",
      
      // Styles ONLY for horizontal tags (Post Cards)
      variant === "inline" && "hover:text-accent hover:opacity-100",
      
      { "text-sm": size === "sm" },
      { "text-lg": size === "lg" },
    ]}
  >
    <IconHash
      class:list={[
        "mr-1",
        { "size-5": size === "lg" },
        { "size-4": size === "sm" },
      ]}
    />
    <span class="font-medium">{tagName}</span>
  </a>
</li>