---
import type { CollectionEntry } from "astro:content";
import { slugifyStr } from "@/utils/slugify";
import { BLOG_PATH } from "@/content.config";
import { getPath } from "@/utils/getPath";
import Datetime from "./Datetime.astro";

type Props = {
  variant?: "h2" | "h3";
} & CollectionEntry<"blog">;

const { variant: Heading = "h2", id, data, filePath } = Astro.props;

const { title, description, ...props } = data;

const pathname = Astro.url?.pathname ?? "/";

// derive room/folder name from filePath (e.g. "reactor", "synthesizer")
const roomName = (() => {
  if (!filePath) return "";
  try {
    const segments = filePath.replace(BLOG_PATH, "").split("/").filter(Boolean);
    return segments.length > 0 ? segments[0] : "";
  } catch (e) {
    return "";
  }
})();

const room = roomName ? `the ${roomName}` : "";
const hideRoomLabel = roomName
  ? new RegExp(`/notes/${roomName}(/|$)`).test(pathname)
  : false;
---

<li class="my-6">
  <div class="inline-flex items-center gap-2">
    <Heading style={{ viewTransitionName: slugifyStr(title.replaceAll(".", "-")) }}>
      <a
        href={getPath(id, filePath)}
        class:list={[
          "inline-block text-lg font-medium text-accent",
          "underline-offset-4 hover:underline",
          "focus-visible:no-underline focus-visible:underline-offset-0",
        ]}
      >
        {title}
      </a>
    </Heading>
    {roomName && !hideRoomLabel && (
      <a
        href={`/notes/${roomName}/`}
        class="ml-2 rounded-full px-2 py-0.5 text-xs font-semibold"
        style={{ color: "#0FFFF3", backgroundColor: "rgba(15, 255, 243, 0.12)" }}
      >
        {room}
      </a>
    )}
  </div>
  <Datetime {...props} />
  <p>{description}</p>
</li>
